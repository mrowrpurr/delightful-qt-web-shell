# Build output
build/
.xmake/
compile_commands/

# Generated by before_build (rcc + qrc)
desktop/web_dist.qrc
desktop/web_dist_resources.cpp

# Generated by xmake from APP_NAME/APP_SLUG
desktop/resources/app.rc
build/.desktop-binary.txt

# WASM build artifacts copied by dev-wasm
web/public/wasm-app.*
web/apps/main/public/wasm-app.*

# Desktop screenshots (tools/screenshot.py default output)
screenshot.png

# Dependencies
node_modules/

# Vite / TypeScript build output
dist/
*.tsbuildinfo

# Test output
test-results/

# Binary files
*.exe
*.dll

# Logs
*.log

# OS junk
.DS_Store
Thumbs.db

# Android
android/.gradle/
android/*/build/
android/local.properties
android/app/src/main/assets/
android/app/.cxx/
*.apk

# Python
__pycache__/
*.py[cod]

# Secrets
.env
.env.*
!.env.example

# Agent handoff or kickoff documents (keep local, never commit)
*[Hh][Aa][Nn][Dd][Oo][Ff][Ff]*
*[Kk][Ii][Cc][Kk][Oo][Ff][Ff]*
