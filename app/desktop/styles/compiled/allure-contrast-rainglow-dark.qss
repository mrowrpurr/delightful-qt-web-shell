/* Auto-generated — Allure Contrast (rainglow) (dark) */


QWidget {
  background-color: hsl(216, 9.8%, 10%);
  color: hsl(213.3, 27.3%, 80.6%);
}

QMainWindow {
  background-color: hsl(216, 9.8%, 10%);
}

QMainWindow::separator {
  background-color: hsl(240, 1.3%, 14.7%);
  width: 1px;
  height: 1px;
}

QMenuBar {
  background-color: hsl(216, 9.8%, 10%);
  color: hsl(213.3, 27.3%, 80.6%);
  border-bottom: 1px solid hsl(240, 1.3%, 14.7%);
}

QMenuBar::item {
  padding: 4px 8px;
  background: transparent;
}

QMenuBar::item:selected {
  background-color: hsl(216, 4.9%, 20%);
  color: hsl(0, 0%, 100%);
  border-radius: 4px;
}

QMenu {
  background-color: hsl(220, 9.7%, 6.1%);
  color: hsl(0, 0%, 80%);
  border: 1px solid hsl(240, 1.3%, 14.7%);
  border-radius: 6px;
  padding: 4px;
}

QMenu::item {
  padding: 6px 24px 6px 12px;
  border-radius: 4px;
}

QMenu::item:selected {
  background-color: hsl(216, 4.9%, 20%);
  color: hsl(0, 0%, 100%);
}

QMenu::item:disabled {
  color: hsl(213.3, 8.2%, 50%);
}

QMenu::separator {
  height: 1px;
  background: hsl(240, 1.3%, 14.7%);
  margin: 4px 8px;
}

QTabWidget::pane {
  background-color: hsl(216, 9.8%, 10%);
  border: none;
}

QTabBar {
  background-color: hsl(216, 9.8%, 10%);
}

QTabBar::tab {
  background-color: hsl(216, 4.9%, 20%);
  color: hsl(216, 1%, 99%);
  padding: 6px 16px;
  border: none;
  border-bottom: 2px solid transparent;
}

QTabBar::tab:selected {
  background-color: hsl(216, 9.8%, 10%);
  color: hsl(213.3, 27.3%, 80.6%);
  border-bottom: 2px solid hsl(162.4, 30.1%, 51.2%);
}

QTabBar::tab:hover:!selected {
  background-color: hsl(216, 4.9%, 20%);
  color: hsl(0, 0%, 100%);
}

QTabBar::close-button {
  image: none;
}

QToolBar {
  background-color: hsl(216, 9.8%, 10%);
  border-bottom: 1px solid hsl(240, 1.3%, 14.7%);
  spacing: 2px;
  padding: 2px;
}

QToolButton {
  background: transparent;
  color: hsl(213.3, 27.3%, 80.6%);
  border: none;
  border-radius: 4px;
  padding: 4px 8px;
}

QToolButton:hover {
  background-color: hsl(216, 4.9%, 20%);
  color: hsl(0, 0%, 100%);
}

QToolButton:pressed {
  background-color: hsl(162.4, 30.1%, 51.2%);
  color: hsl(162.4, 6%, 99%);
}

QStatusBar {
  background-color: hsl(216, 9.8%, 10%);
  color: hsl(213.3, 8.2%, 50%);
  border-top: 1px solid hsl(240, 1.3%, 14.7%);
}

QStatusBar::item {
  border: none;
}

QPushButton {
  background-color: hsl(162.4, 30.1%, 51.2%);
  color: hsl(162.4, 6%, 99%);
  border: none;
  border-radius: 6px;
  padding: 6px 16px;
  font-weight: bold;
}

QPushButton:hover {
  background-color: hsl(162.4, 30.1%, 51.2%);
}

QPushButton:pressed {
  background-color: hsl(162.4, 30.1%, 51.2%);
  opacity: 0.9;
}

QPushButton:disabled {
  background-color: hsl(216, 2.9%, 17%);
  color: hsl(213.3, 8.2%, 50%);
}
QPushButton[class~="destructive"] {
  background-color: hsl(0, 63%, 31%);
  color: hsl(0, 0%, 98%);
}
QPushButton[class~="secondary"] {
  background-color: hsl(216, 4.9%, 20%);
  color: hsl(216, 1%, 99%);
}

QPushButton[class~="ghost"] {
  background-color: transparent;
  color: hsl(213.3, 27.3%, 80.6%);
}

QPushButton[class~="ghost"]:hover {
  background-color: hsl(216, 4.9%, 20%);
  color: hsl(0, 0%, 100%);
}

QScrollBar:vertical {
  background: transparent;
  width: 10px;
  margin: 0;
}

QScrollBar::handle:vertical {
  background-color: hsl(216, 2.9%, 17%);
  border-radius: 5px;
  min-height: 20px;
}

QScrollBar::handle:vertical:hover {
  background-color: hsl(213.3, 8.2%, 50%);
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
  height: 0;
}

QScrollBar:horizontal {
  background: transparent;
  height: 10px;
  margin: 0;
}

QScrollBar::handle:horizontal {
  background-color: hsl(216, 2.9%, 17%);
  border-radius: 5px;
  min-height: 20px;
}

QScrollBar::handle:horizontal:hover {
  background-color: hsl(213.3, 8.2%, 50%);
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
  width: 0;
}

QLineEdit, QTextEdit, QPlainTextEdit {
  background-color: hsl(216, 9.8%, 10%);
  color: hsl(213.3, 27.3%, 80.6%);
  border: 1px solid hsl(240, 1.3%, 14.7%);
  border-radius: 6px;
  padding: 6px 10px;
  selection-background-color: hsl(162.4, 30.1%, 51.2%);
  selection-color: hsl(162.4, 6%, 99%);
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
  border-color: hsl(162.4, 30.1%, 51.2%);
}

QComboBox {
  background-color: hsl(216, 9.8%, 10%);
  color: hsl(213.3, 27.3%, 80.6%);
  border: 1px solid hsl(240, 1.3%, 14.7%);
  border-radius: 6px;
  padding: 6px 10px;
}

QComboBox::drop-down {
  subcontrol-origin: padding;
  subcontrol-position: top right;
  width: 24px;
  border-left: 1px solid hsl(240, 1.3%, 14.7%);
}

QComboBox::down-arrow {
  image: url(:/down-arrow.svg);
  width: 12px;
  height: 8px;
}

QComboBox QAbstractItemView {
  background-color: hsl(220, 9.7%, 6.1%);
  color: hsl(0, 0%, 80%);
  border: 1px solid hsl(240, 1.3%, 14.7%);
  selection-background-color: hsl(216, 4.9%, 20%);
  selection-color: hsl(0, 0%, 100%);
}

QCheckBox, QRadioButton {
  color: hsl(213.3, 27.3%, 80.6%);
  spacing: 8px;
}

QCheckBox::indicator, QRadioButton::indicator {
  width: 16px;
  height: 16px;
  border: 1px solid hsl(240, 1.3%, 14.7%);
  border-radius: 3px;
  background-color: hsl(216, 9.8%, 10%);
}

QCheckBox::indicator:checked {
  background-color: hsl(162.4, 30.1%, 51.2%);
  border-color: hsl(162.4, 30.1%, 51.2%);
}

QRadioButton::indicator {
  border-radius: 8px;
}

QRadioButton::indicator:checked {
  background-color: hsl(162.4, 30.1%, 51.2%);
  border-color: hsl(162.4, 30.1%, 51.2%);
}

QDialog {
  background-color: hsl(220, 9.7%, 12.2%);
  color: hsl(213.3, 27.3%, 80.6%);
}

QMessageBox {
  background-color: hsl(220, 9.7%, 12.2%);
  color: hsl(213.3, 27.3%, 80.6%);
}

QGroupBox {
  border: 1px solid hsl(240, 1.3%, 14.7%);
  border-radius: 6px;
  margin-top: 12px;
  padding-top: 16px;
  color: hsl(213.3, 27.3%, 80.6%);
}

QGroupBox::title {
  subcontrol-origin: margin;
  left: 12px;
  padding: 0 4px;
  color: hsl(213.3, 27.3%, 80.6%);
}

QToolTip {
  background-color: hsl(220, 9.7%, 6.1%);
  color: hsl(0, 0%, 80%);
  border: 1px solid hsl(240, 1.3%, 14.7%);
  border-radius: 4px;
  padding: 4px 8px;
}

QProgressBar {
  background-color: hsl(216, 4.9%, 20%);
  border: none;
  border-radius: 4px;
  text-align: center;
  color: hsl(213.3, 27.3%, 80.6%);
}

QProgressBar::chunk {
  background-color: hsl(162.4, 30.1%, 51.2%);
  border-radius: 4px;
}

QSplitter::handle {
  background-color: hsl(240, 1.3%, 14.7%);
}

QSplitter::handle:horizontal {
  width: 1px;
}

QSplitter::handle:vertical {
  height: 1px;
}
