/* Auto-generated — Yellow (dark) */


QWidget {
  background-color: hsl(20, 14.3%, 4.1%);
  color: hsl(60, 9.1%, 97.8%);
}

QMainWindow {
  background-color: hsl(20, 14.3%, 4.1%);
}

QMainWindow::separator {
  background-color: hsl(12, 6.5%, 15.1%);
  width: 1px;
  height: 1px;
}

QMenuBar {
  background-color: hsl(20, 14.3%, 4.1%);
  color: hsl(60, 9.1%, 97.8%);
  border-bottom: 1px solid hsl(12, 6.5%, 15.1%);
}

QMenuBar::item {
  padding: 4px 8px;
  background: transparent;
}

QMenuBar::item:selected {
  background-color: hsl(12, 6.5%, 15.1%);
  color: hsl(60, 9.1%, 97.8%);
  border-radius: 4px;
}

QMenu {
  background-color: hsl(20, 14.3%, 4.1%);
  color: hsl(60, 9.1%, 97.8%);
  border: 1px solid hsl(12, 6.5%, 15.1%);
  border-radius: 6px;
  padding: 4px;
}

QMenu::item {
  padding: 6px 24px 6px 12px;
  border-radius: 4px;
}

QMenu::item:selected {
  background-color: hsl(12, 6.5%, 15.1%);
  color: hsl(60, 9.1%, 97.8%);
}

QMenu::item:disabled {
  color: hsl(24, 5.4%, 63.9%);
}

QMenu::separator {
  height: 1px;
  background: hsl(12, 6.5%, 15.1%);
  margin: 4px 8px;
}

QTabWidget::pane {
  background-color: hsl(20, 14.3%, 4.1%);
  border: none;
}

QTabBar {
  background-color: hsl(20, 14.3%, 4.1%);
}

QTabBar::tab {
  background-color: hsl(12, 6.5%, 15.1%);
  color: hsl(60, 9.1%, 97.8%);
  padding: 6px 16px;
  border: none;
  border-bottom: 2px solid transparent;
}

QTabBar::tab:selected {
  background-color: hsl(20, 14.3%, 4.1%);
  color: hsl(60, 9.1%, 97.8%);
  border-bottom: 2px solid hsl(47.9, 95.8%, 53.1%);
}

QTabBar::tab:hover:!selected {
  background-color: hsl(12, 6.5%, 15.1%);
  color: hsl(60, 9.1%, 97.8%);
}

QTabBar::close-button {
  image: none;
}

QToolBar {
  background-color: hsl(20, 14.3%, 4.1%);
  border-bottom: 1px solid hsl(12, 6.5%, 15.1%);
  spacing: 2px;
  padding: 2px;
}

QToolButton {
  background: transparent;
  color: hsl(60, 9.1%, 97.8%);
  border: none;
  border-radius: 4px;
  padding: 4px 8px;
}

QToolButton:hover {
  background-color: hsl(12, 6.5%, 15.1%);
  color: hsl(60, 9.1%, 97.8%);
}

QToolButton:pressed {
  background-color: hsl(47.9, 95.8%, 53.1%);
  color: hsl(26, 83.3%, 14.1%);
}

QStatusBar {
  background-color: hsl(20, 14.3%, 4.1%);
  color: hsl(24, 5.4%, 63.9%);
  border-top: 1px solid hsl(12, 6.5%, 15.1%);
}

QStatusBar::item {
  border: none;
}

QPushButton {
  background-color: hsl(47.9, 95.8%, 53.1%);
  color: hsl(26, 83.3%, 14.1%);
  border: none;
  border-radius: 6px;
  padding: 6px 16px;
  font-weight: bold;
}

QPushButton:hover {
  background-color: hsl(35.5, 91.7%, 32.9%);
}

QPushButton:pressed {
  background-color: hsl(47.9, 95.8%, 53.1%);
  opacity: 0.9;
}

QPushButton:disabled {
  background-color: hsl(12, 6.5%, 15.1%);
  color: hsl(24, 5.4%, 63.9%);
}
QPushButton[class~="destructive"] {
  background-color: hsl(0, 62.8%, 30.6%);
  color: hsl(60, 9.1%, 97.8%);
}
QPushButton[class~="secondary"] {
  background-color: hsl(12, 6.5%, 15.1%);
  color: hsl(60, 9.1%, 97.8%);
}

QPushButton[class~="ghost"] {
  background-color: transparent;
  color: hsl(60, 9.1%, 97.8%);
}

QPushButton[class~="ghost"]:hover {
  background-color: hsl(12, 6.5%, 15.1%);
  color: hsl(60, 9.1%, 97.8%);
}

QScrollBar:vertical {
  background: transparent;
  width: 10px;
  margin: 0;
}

QScrollBar::handle:vertical {
  background-color: hsl(12, 6.5%, 15.1%);
  border-radius: 5px;
  min-height: 20px;
}

QScrollBar::handle:vertical:hover {
  background-color: hsl(24, 5.4%, 63.9%);
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
  height: 0;
}

QScrollBar:horizontal {
  background: transparent;
  height: 10px;
  margin: 0;
}

QScrollBar::handle:horizontal {
  background-color: hsl(12, 6.5%, 15.1%);
  border-radius: 5px;
  min-height: 20px;
}

QScrollBar::handle:horizontal:hover {
  background-color: hsl(24, 5.4%, 63.9%);
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
  width: 0;
}

QLineEdit, QTextEdit, QPlainTextEdit {
  background-color: hsl(20, 14.3%, 4.1%);
  color: hsl(60, 9.1%, 97.8%);
  border: 1px solid hsl(12, 6.5%, 15.1%);
  border-radius: 6px;
  padding: 6px 10px;
  selection-background-color: hsl(47.9, 95.8%, 53.1%);
  selection-color: hsl(26, 83.3%, 14.1%);
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
  border-color: hsl(35.5, 91.7%, 32.9%);
}

QComboBox {
  background-color: hsl(20, 14.3%, 4.1%);
  color: hsl(60, 9.1%, 97.8%);
  border: 1px solid hsl(12, 6.5%, 15.1%);
  border-radius: 6px;
  padding: 6px 10px;
}

QComboBox::drop-down {
  subcontrol-origin: padding;
  subcontrol-position: top right;
  width: 24px;
  border-left: 1px solid hsl(12, 6.5%, 15.1%);
}

QComboBox::down-arrow {
  image: url(:/down-arrow.svg);
  width: 12px;
  height: 8px;
}

QComboBox QAbstractItemView {
  background-color: hsl(20, 14.3%, 4.1%);
  color: hsl(60, 9.1%, 97.8%);
  border: 1px solid hsl(12, 6.5%, 15.1%);
  selection-background-color: hsl(12, 6.5%, 15.1%);
  selection-color: hsl(60, 9.1%, 97.8%);
}

QCheckBox, QRadioButton {
  color: hsl(60, 9.1%, 97.8%);
  spacing: 8px;
}

QCheckBox::indicator, QRadioButton::indicator {
  width: 16px;
  height: 16px;
  border: 1px solid hsl(12, 6.5%, 15.1%);
  border-radius: 3px;
  background-color: hsl(20, 14.3%, 4.1%);
}

QCheckBox::indicator:checked {
  background-color: hsl(47.9, 95.8%, 53.1%);
  border-color: hsl(47.9, 95.8%, 53.1%);
}

QRadioButton::indicator {
  border-radius: 8px;
}

QRadioButton::indicator:checked {
  background-color: hsl(47.9, 95.8%, 53.1%);
  border-color: hsl(47.9, 95.8%, 53.1%);
}

QDialog {
  background-color: hsl(20, 14.3%, 4.1%);
  color: hsl(60, 9.1%, 97.8%);
}

QMessageBox {
  background-color: hsl(20, 14.3%, 4.1%);
  color: hsl(60, 9.1%, 97.8%);
}

QGroupBox {
  border: 1px solid hsl(12, 6.5%, 15.1%);
  border-radius: 6px;
  margin-top: 12px;
  padding-top: 16px;
  color: hsl(60, 9.1%, 97.8%);
}

QGroupBox::title {
  subcontrol-origin: margin;
  left: 12px;
  padding: 0 4px;
  color: hsl(60, 9.1%, 97.8%);
}

QToolTip {
  background-color: hsl(20, 14.3%, 4.1%);
  color: hsl(60, 9.1%, 97.8%);
  border: 1px solid hsl(12, 6.5%, 15.1%);
  border-radius: 4px;
  padding: 4px 8px;
}

QProgressBar {
  background-color: hsl(12, 6.5%, 15.1%);
  border: none;
  border-radius: 4px;
  text-align: center;
  color: hsl(60, 9.1%, 97.8%);
}

QProgressBar::chunk {
  background-color: hsl(47.9, 95.8%, 53.1%);
  border-radius: 4px;
}

QSplitter::handle {
  background-color: hsl(12, 6.5%, 15.1%);
}

QSplitter::handle:horizontal {
  width: 1px;
}

QSplitter::handle:vertical {
  height: 1px;
}
